# Temporada atual da NBA (ajustar conforme necessário)
NBA_SEASON=2025
# Banco de Dados (PostgreSQL)
POSTGRES_USER=seu_user
POSTGRES_PASSWORD=sua_senha
POSTGRES_DB=nba_score_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_EMAIL=seu_email
PGADMIN_PASSWORD=sua_senha

# API-Sports (NBA v2)
API_SPORTS_KEY=sua_chave_api
API_SPORTS_BASE_URL=https://v2.nba.api-sports.io

# Backend / FastAPI
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_ENV=development

# Origem do frontend (se necessário para CORS futuramente)
FRONTEND_ORIGIN=http://localhost:8000

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=sua_chave_api
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Credenciais Airflow Web UI
AIRFLOW_ADMIN_USERNAME=seu_user
AIRFLOW_ADMIN_PASSWORD=sua_senha
AIRFLOW_ADMIN_EMAIL=seu_email
# Conexão DB para Airflow (ex: postgres backend)
AIRFLOW_DB_USER=seu_user
AIRFLOW_DB_PASSWORD=sua_senha
AIRFLOW_DB_NAME=airflow_db
AIRFLOW_DB_HOST=postgres
AIRFLOW_DB_PORT=5432

# OpenAI (Fallback opcional)
OPENAI_API_KEY=sua_chave_api
OPENAI_MODEL_NAME=gpt-4o-mini

SECRET_KEY=sua_senha
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Misc / Observabilidade
LOG_LEVEL=INFO

# Margens Modelo
MARGEM_PONTOS=3.0
MARGEM_ASSISTENCIAS=1.5
MARGEM_REBOTES=2.0
MARGEM_ROUBOS=1.0
MARGEM_BLOQUEIOS=1.0
MIN_MINUTOS_PALPITE=15.0

PASTA_MODELOS=/opt/airflow/modelos_ml

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USUARIO=seu@gmail.com
SMTP_SENHA=sua_senha_de_app
SMTP_REMETENTE=NbaAnalytics <seu@gmail.com>
FRONTEND_URL=https://nbaanalytics.com.br