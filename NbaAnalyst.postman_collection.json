        {
          "name": "Comparar dois times 🔒",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/times/comparar?time1_id=1&time2_id=2&temporada={{temporada}}",
              "host": ["{{base_url}}"], "path": ["times","comparar"],
              "query": [
